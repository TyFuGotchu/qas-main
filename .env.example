# ─── Database ───────────────────────────────────────────────
# PostgreSQL (production — required on Vercel)
DATABASE_URL="postgresql://user:password@host:5432/quicksilver_algo?schema=public"
# SQLite (local dev only)
# DATABASE_URL="file:./dev.db"

# ─── Authentication ─────────────────────────────────────────
# Session signing secret (required in production)
NEXTAUTH_SECRET="change-this-to-a-secure-random-string-in-production"
# Legacy alias — either NEXTAUTH_SECRET or JWT_SECRET is accepted
# JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_TIER_1="price_..."
STRIPE_PRICE_ID_TIER_2="price_..."
STRIPE_PRICE_ID_TIER_3="price_..."

# ─── Partner Links ──────────────────────────────────────────
HEROFX_PARTNER_LINK="https://herofx.co/?partner_code=9149459"

# ─── Application ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_SITE_URL="https://quicksilveralgo.com"
ADMIN_EMAIL="admin@yourdomain.com"

# ─── Onboarding Emails (Resend) ─────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Quicksilver Algo <onboarding@quicksilveralgo.com>"
ONBOARDING_INTERNAL_SECRET=""

# ─── Market Data (live feeds — falls back to mock if unset) ───
# Twelve Data: XAUUSD, XAGUSD, NAS100, BTC prices, candles, ATR
TWELVE_DATA_API_KEY=""
# Finnhub: economic calendar, forex/general news, sentiment scoring
FINNHUB_API_KEY=""